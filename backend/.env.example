# ===== Google OAuth (from Google Cloud Console) =====
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# ===== Google Drive folder IDs =====
# Get these from the folder URL: https://drive.google.com/drive/folders/<THIS_PART>
GOOGLE_DRIVE_FOLDER_VIDEO=
GOOGLE_DRIVE_FOLDER_DOCUMENT=

# ===== JWT =====
# Generate a strong secret:  openssl rand -hex 32
JWT_SECRET=change-me-please-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ===== Database =====
DATABASE_URL=sqlite:///./app.db

# ===== CORS / Frontend =====
FRONTEND_ORIGIN=http://localhost:3000

# ===== Default admin (created only on first run) =====
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin1234
